{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velocity-Bridge",
  "version": "2.0.6",
  "identifier": "com.arsh.velocity-bridge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Velocity Bridge",
        "width": 1000,
        "height": 750
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "server"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Trex099/Velocity-Bridge/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBMkQwQUE5QjQzNjZBRDMKUldUVGFqYTBxUW90Nm11bk1ya2h2eVQ1dWF4QmsrOXNhK2QvOW5NdWJoQXA5WlF4MW5TUzlEWHkK"
    }
  }
}