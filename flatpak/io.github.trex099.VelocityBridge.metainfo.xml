<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.trex099.VelocityBridge</id>
  <name>Velocity Bridge</name>
  <summary>iOS to Linux Clipboard Sync</summary>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  
  <developer id="io.github.trex099">
    <name>Trex099</name>
  </developer>
  
  <description>
    <p>
      Copy on iPhone. Paste on Linux. That's it.
    </p>
    <p>
      Velocity Bridge syncs your iPhone clipboard to your Linux desktop over your local network.
      No cloud, no subscription, just copy and paste.
    </p>
    <p>Features:</p>
    <ul>
      <li>Text clipboard sync</li>
      <li>Image clipboard sync (HEIC to PNG conversion)</li>
      <li>URL auto-open in browser</li>
      <li>Desktop notifications</li>
      <li>System tray integration</li>
      <li>QR codes for easy iOS setup</li>
    </ul>
  </description>
  
  <url type="homepage">https://github.com/Trex099/Velocity-Bridge</url>
  <url type="bugtracker">https://github.com/Trex099/Velocity-Bridge/issues</url>
  
  <launchable type="desktop-id">io.github.trex099.VelocityBridge.desktop</launchable>
  
  <screenshots>
    <screenshot type="default">
      <caption>Dashboard showing server status and connection info</caption>
      <image>https://raw.githubusercontent.com/Trex099/Velocity-Bridge/main/assets/screenshot-dashboard.png</image>
    </screenshot>
  </screenshots>
  
  <content_rating type="oars-1.1" />
  
  <releases>
    <release version="1.0.2" date="2024-12-08">
      <description>
        <p>Initial Flathub release</p>
        <ul>
          <li>Text and image clipboard sync</li>
          <li>GUI with system tray</li>
          <li>Token persistence</li>
          <li>Live logs</li>
        </ul>
      </description>
    </release>
  </releases>
  
  <categories>
    <category>Utility</category>
    <category>Network</category>
  </categories>
  
  <keywords>
    <keyword>clipboard</keyword>
    <keyword>sync</keyword>
    <keyword>ios</keyword>
    <keyword>iphone</keyword>
    <keyword>paste</keyword>
  </keywords>
  
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>
</component>
